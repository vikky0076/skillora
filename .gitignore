.grunt

# Bower dependency directory (bower_components)
bower_components

# node-modules
node_modules/
jspm_packages/

# Snowpack dependency directory (.snowpack)
.snowpack

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

